---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const dictionary = await getCollection('dictionary');
  return dictionary.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Generate link to category
const categorySlug = entry.data.category.toLowerCase().replace(/[^a-z0-9]+/g, '-');
---

<Layout title={entry.data.term} description={`Meaning and definition of ${entry.data.term} in Software Engineering.`}>
	<div class="container term-page">
		<a href="/dictionary" class="back-link">← Back to Dictionary</a>
		
		<article class="term-content">
			<header class="term-header">
				<div class="term-meta">
					<a href={`/categories/${categorySlug}`} class="meta-item category-meta">{entry.data.category}</a>
					<span class="badge" data-level={entry.data.level}>{entry.data.level}</span>
				</div>
				<h1 class="term-title">{entry.data.term}</h1>
			</header>

			<div class="prose">
				<Content />
			</div>
		</article>

		<div class="continue-learning">
			<h3>Continue Learning</h3>
			<p>Explore more terms in the <a href={`/categories/${categorySlug}`}>{entry.data.category}</a> category.</p>
		</div>
	</div>
</Layout>

<style>
	.term-page {
		padding: 40px 24px 80px;
		max-width: 800px;
	}

	.back-link {
		color: var(--text-muted);
		font-size: 0.95rem;
		display: inline-block;
		margin-bottom: 32px;
	}

	.back-link:hover {
		color: var(--text-primary);
	}

	.term-content {
		background: var(--surface-color);
		border: 1px solid var(--border-color);
		border-radius: 16px;
		padding: 40px;
		box-shadow: 0 20px 40px -20px rgba(0, 0, 0, 0.5);
	}

	.term-header {
		margin-bottom: 32px;
		border-bottom: 1px solid var(--border-color);
		padding-bottom: 24px;
	}

	.term-meta {
		display: flex;
		align-items: center;
		gap: 16px;
		margin-bottom: 16px;
	}

	.meta-item {
		font-size: 0.85rem;
		color: var(--text-secondary);
	}

	.category-meta {
		background: rgba(255, 255, 255, 0.05);
		padding: 4px 12px;
		border-radius: 999px;
	}

	.category-meta:hover {
		background: rgba(255, 255, 255, 0.1);
		color: var(--text-primary);
	}

	.term-title {
		font-size: 3rem;
		letter-spacing: -0.5px;
	}

	/* Markdown Content Styling */
	.prose {
		color: var(--text-secondary);
		font-size: 1.1rem;
		line-height: 1.7;
	}

	.prose :global(h2), .prose :global(h3), .prose :global(h4) {
		color: var(--text-primary);
		margin: 2em 0 1em;
	}

	.prose :global(h3) {
		font-size: 1.25rem;
		text-transform: uppercase;
		letter-spacing: 1px;
		color: var(--accent-color);
		font-family: 'Inter', sans-serif;
	}

	.prose :global(p) {
		margin-bottom: 1.5em;
	}

	.prose :global(p:last-child) {
		margin-bottom: 0;
	}

	.continue-learning {
		margin-top: 40px;
		padding: 24px;
		border-radius: 12px;
		background: rgba(59, 130, 246, 0.05);
		border: 1px solid rgba(59, 130, 246, 0.1);
		text-align: center;
	}

	.continue-learning h3 {
		margin-bottom: 8px;
		color: var(--accent-color);
	}

	.continue-learning a {
		color: var(--text-primary);
		text-decoration: underline;
		text-decoration-color: var(--text-muted);
		text-underline-offset: 4px;
	}

	.continue-learning a:hover {
		text-decoration-color: var(--accent-color);
	}

	@media (max-width: 600px) {
		.term-content {
			padding: 24px;
		}
		
		.term-title {
			font-size: 2rem;
		}
	}
</style>
